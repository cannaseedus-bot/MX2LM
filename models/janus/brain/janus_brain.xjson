{
  "@type": "xcfe/brain",
  "@id": "janus_multimodal_brain",
  "@law": "Ω-BLACK-PANEL",
  "@schema": "../schema/janus.xjson",

  "identity": {
    "name": "Janus Pro",
    "version": "7B",
    "family": "multimodal_unified",
    "architecture": "transformer_diffusion_hybrid",
    "source": "deepseek-ai/Janus-Pro-7B"
  },

  "π_kuhul": {
    "@doc": "π-KUHUL integration layer",
    "constants": {
      "π": 3.141592653589793,
      "φ": 1.6180339887498948,
      "τ": 6.283185307179586,
      "e": 2.718281828459045
    },
    "wave_functions": {
      "encode": "sin(πx) × φ^(-d)",
      "decode": "arcsin(x/φ^d) / π",
      "compress": "⌊x × π × 1000⌋ / 1000"
    },
    "flow_physics": {
      "rectified_flow": "v = (x₁ - x₀)",
      "guidance_scale": "φ × 2",
      "timesteps": 30
    }
  },

  "glyph_codex": {
    "@doc": "Glyph encoding for Janus operations",
    "primitives": {
      "🖼→📝": "image_to_text",
      "📝→🖼": "text_to_image",
      "🖼+📝": "multimodal_fusion",
      "⚡🌀": "diffusion_generate",
      "🔄📊": "flow_compute"
    },
    "opcodes": {
      "JAN_ENC": "⟁J0",
      "JAN_DEC": "⟁J1",
      "JAN_FUS": "⟁J2",
      "JAN_GEN": "⟁J3",
      "JAN_DIF": "⟁J4"
    }
  },

  "xcfe_paths": {
    "@doc": "Control flow paths",
    "understand": ["input_router", "vision_encoder", "fusion", "decoder", "text_output"],
    "generate": ["input_router", "text_encoder", "fusion", "decoder", "diffusion_decoder", "image_output"],
    "chat": ["input_router", "fusion", "decoder", "text_output"]
  },

  "compression_calculus": {
    "@law": "CC-FULL",
    "symbol_folding": {
      "enabled": true,
      "max_depth": 3,
      "glyph_cache": true
    },
    "field_projection": {
      "enabled": true,
      "observers": ["api", "internal", "debug"]
    },
    "control_collapse": {
      "enabled": true,
      "canonical_form": true
    },
    "value_quantization": {
      "enabled": true,
      "precision": "π_ratio",
      "bounds": [-1, 1]
    },
    "temporal_folding": {
      "enabled": true,
      "replay_support": true
    }
  },

  "memory_binding": {
    "ngram_table": "janus_patterns",
    "glyph_weights": "janus_effectiveness",
    "image_embeddings": "janus_visual",
    "text_embeddings": "janus_textual"
  },

  "inference": {
    "modes": {
      "understanding": {
        "input": ["image", "text"],
        "output": "text",
        "temperature": 0.7,
        "max_tokens": 4096
      },
      "generation": {
        "input": "text",
        "output": "image",
        "cfg_scale": 5.0,
        "steps": 30,
        "resolution": [384, 384]
      }
    }
  },

  "api_binding": {
    "local": {
      "enabled": true,
      "device": "cuda",
      "dtype": "bfloat16"
    },
    "remote": {
      "enabled": false,
      "endpoint": null
    }
  }
}
