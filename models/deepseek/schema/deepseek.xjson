{
  "@type": "xcfe/model_schema",
  "@id": "deepseek_v3",
  "@law": "CC-FULL",
  "@version": "3.0.0",

  "Σ": {
    "@doc": "Symbol set for Deepseek",
    "atoms": ["token", "moe_expert", "attention", "mlp", "router"],
    "glyphs": {
      "🧠": "expert_activation",
      "🔀": "moe_routing",
      "⚡": "fast_path",
      "💭": "reasoning",
      "🔧": "code_gen"
    }
  },

  "V": {
    "@doc": "Value bindings",
    "π": 3.141592653589793,
    "φ": 1.6180339887498948,
    "hidden_dim": 7168,
    "num_experts": 256,
    "experts_per_token": 8,
    "num_layers": 61,
    "num_heads": 128,
    "vocab_size": 129280,
    "max_seq_len": 163840
  },

  "Φ": {
    "@doc": "Control structure - MoE routing",
    "entry": "tokenizer",
    "nodes": {
      "tokenizer": {
        "@type": "data/transform",
        "operation": "bpe_encode",
        "next": "embed"
      },
      "embed": {
        "@type": "π/transform",
        "operation": "lookup",
        "dim": 7168,
        "next": "moe_layers"
      },
      "moe_layers": {
        "@type": "control/loop",
        "iterations": 61,
        "body": "moe_block",
        "next": "output_head"
      },
      "moe_block": {
        "@type": "π/transform",
        "components": ["attention", "router", "experts", "combine"],
        "residual": true
      },
      "output_head": {
        "@type": "π/transform",
        "operation": "lm_head",
        "next": "sample"
      },
      "sample": {
        "@type": "control/branch",
        "conditions": {
          "temperature_0": "argmax",
          "temperature_gt_0": "multinomial"
        }
      }
    }
  },

  "compression": {
    "@law": "CC-v1",
    "operators": ["⊕", "π̂", "⊗", "≈", "τ"],
    "moe_compression": {
      "expert_pruning": false,
      "activation_sparsity": 0.9375,
      "routing_compression": true
    }
  },

  "capabilities": {
    "reasoning": true,
    "code_generation": true,
    "math": true,
    "long_context": true,
    "moe_architecture": true
  },

  "adapters": {
    "kuhul_pi": {
      "wave_transform": true,
      "golden_compression": true,
      "moe_routing_glyph": true
    }
  }
}
