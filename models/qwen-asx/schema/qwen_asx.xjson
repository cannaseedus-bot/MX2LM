{
  "@type": "xcfe/model_schema",
  "@id": "qwen_asx_base",
  "@law": "CC-FULL",
  "@version": "1.0.0",
  "@role": "base_training_format",

  "Σ": {
    "@doc": "Symbol set for Qwen-ASX (MX2LM base training model)",
    "atoms": ["token", "embedding", "attention", "ffn", "rmsnorm", "logits", "delta"],
    "glyphs": {
      "🧬": "base_format",
      "🎓": "training_source",
      "⚙️": "safetensors",
      "📊": "weight_delta",
      "🔄": "rlhf_update",
      "✅": "conformance"
    }
  },

  "V": {
    "@doc": "Value bindings - Qwen-ASX architecture",
    "π": 3.141592653589793,
    "φ": 1.6180339887498948,
    "τ": 6.283185307179586,
    "d_model": 768,
    "d_ff": 3072,
    "n_layers": 12,
    "n_heads": 12,
    "vocab_size": 151936,
    "max_seq_len": 8192,
    "rope_theta": 10000.0
  },

  "Φ": {
    "@doc": "Control structure - Decoder-only transformer",
    "entry": "tokenizer",
    "nodes": {
      "tokenizer": {
        "@type": "data/transform",
        "operation": "tiktoken_encode",
        "next": "embedding"
      },
      "embedding": {
        "@type": "π/transform",
        "operation": "lookup",
        "weights": ["embedding.weight"],
        "dim": 768,
        "next": "transformer_layers"
      },
      "transformer_layers": {
        "@type": "control/loop",
        "iterations": 12,
        "body": "transformer_block",
        "next": "norm_out"
      },
      "transformer_block": {
        "@type": "π/transform",
        "components": ["attention", "ffn"],
        "attention": {
          "weights": ["attn.q_proj", "attn.k_proj", "attn.v_proj", "attn.o_proj"],
          "rope": true
        },
        "ffn": {
          "weights": ["mlp.gate_proj", "mlp.up_proj", "mlp.down_proj"],
          "activation": "silu"
        },
        "residual": true,
        "norm": "rmsnorm"
      },
      "norm_out": {
        "@type": "π/transform",
        "operation": "rmsnorm",
        "weights": ["norm.weight"],
        "next": "lm_head"
      },
      "lm_head": {
        "@type": "π/transform",
        "operation": "linear",
        "weights": ["lm_head.weight"],
        "next": "sample"
      },
      "sample": {
        "@type": "control/branch",
        "conditions": {
          "temperature_0": "argmax",
          "temperature_gt_0": "top_p_sampling"
        }
      }
    }
  },

  "tensor_format": {
    "@doc": "SafeTensors specification",
    "format": "safetensors",
    "dtype": "float32",
    "layout": "row_major",
    "header": {
      "u64_length": true,
      "json_metadata": true
    }
  },

  "training_role": {
    "@doc": "Role in MX2LM ecosystem",
    "is_base": true,
    "trains_mx2lm": true,
    "external_visibility": "multiple_brains_only",
    "internal_role": "base_format_provider",
    "delta_mode": "rlhf_only"
  },

  "compression": {
    "@law": "CC-v1",
    "operators": ["⊕", "π̂", "⊗", "≈", "τ"],
    "weight_compression": {
      "base": "safetensors_raw",
      "deltas": "scxq2_lane_packed"
    }
  },

  "conformance": {
    "@suite": "infer_min_v1",
    "invariants": {
      "shape": "logits.length == vocab_size",
      "determinism": "same_input_same_hash",
      "finite": "no_nan_no_inf"
    }
  },

  "adapters": {
    "kuhul_pi": {
      "wave_transform": true,
      "golden_compression": true,
      "base_glyph": true
    }
  }
}
