{
  "@type": "xcfe/model_schema",
  "@id": "mistral_v1",
  "@law": "CC-FULL",
  "@version": "1.0.0",

  "Σ": {
    "@doc": "Symbol set for Mistral",
    "atoms": ["token", "attention", "mlp", "rope", "sliding_window"],
    "glyphs": {
      "🌬️": "mistral_gen",
      "🪟": "sliding_attention",
      "⚡": "fast_decode",
      "🔄": "rope_position",
      "💬": "chat_mode"
    }
  },

  "V": {
    "@doc": "Value bindings",
    "π": 3.141592653589793,
    "φ": 1.6180339887498948,
    "hidden_dim": 4096,
    "num_layers": 32,
    "num_heads": 32,
    "num_kv_heads": 8,
    "vocab_size": 32000,
    "sliding_window": 4096,
    "max_seq_len": 32768
  },

  "Φ": {
    "@doc": "Control structure - Sliding Window Attention",
    "entry": "tokenizer",
    "nodes": {
      "tokenizer": {
        "@type": "data/transform",
        "operation": "sentencepiece_encode",
        "next": "embed"
      },
      "embed": {
        "@type": "π/transform",
        "operation": "lookup",
        "dim": 4096,
        "next": "transformer_layers"
      },
      "transformer_layers": {
        "@type": "control/loop",
        "iterations": 32,
        "body": "transformer_block",
        "next": "output_head"
      },
      "transformer_block": {
        "@type": "π/transform",
        "components": ["rope_embed", "sliding_attention", "mlp"],
        "residual": true,
        "grouped_query": true
      },
      "output_head": {
        "@type": "π/transform",
        "operation": "lm_head",
        "next": "sample"
      },
      "sample": {
        "@type": "control/branch",
        "conditions": {
          "temperature_0": "argmax",
          "temperature_gt_0": "multinomial"
        }
      }
    }
  },

  "compression": {
    "@law": "CC-v1",
    "operators": ["⊕", "π̂", "⊗", "≈", "τ"],
    "sliding_compression": {
      "window_reuse": true,
      "kv_cache_optimization": true
    }
  },

  "capabilities": {
    "instruction_following": true,
    "code_generation": true,
    "function_calling": true,
    "sliding_window_attention": true,
    "grouped_query_attention": true
  },

  "adapters": {
    "kuhul_pi": {
      "wave_transform": true,
      "golden_compression": true,
      "sliding_glyph": true
    }
  }
}
