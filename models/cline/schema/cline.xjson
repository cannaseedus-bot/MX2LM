{
  "@type": "xcfe/model_schema",
  "@id": "cline_agent_v1",
  "@law": "CC-FULL",
  "@version": "1.0.0",
  "@runtime": "java",

  "Σ": {
    "@doc": "Symbol set for Cline Agent",
    "atoms": ["task", "tool", "action", "result", "context"],
    "glyphs": {
      "🤖": "agent_action",
      "🔧": "tool_use",
      "📁": "file_operation",
      "💻": "terminal_command",
      "🔍": "search_action"
    }
  },

  "V": {
    "@doc": "Value bindings",
    "π": 3.141592653589793,
    "φ": 1.6180339887498948,
    "max_iterations": 100,
    "tool_timeout_ms": 30000,
    "context_window": 128000,
    "action_history_size": 50
  },

  "Φ": {
    "@doc": "Control structure - Agent Loop",
    "entry": "task_input",
    "nodes": {
      "task_input": {
        "@type": "data/input",
        "format": "user_task",
        "next": "context_gather"
      },
      "context_gather": {
        "@type": "π/transform",
        "operation": "gather_context",
        "sources": ["files", "terminal", "browser"],
        "next": "action_plan"
      },
      "action_plan": {
        "@type": "π/transform",
        "operation": "llm_plan",
        "model": "configurable",
        "next": "action_router"
      },
      "action_router": {
        "@type": "control/branch",
        "conditions": {
          "file_operation": "file_tool",
          "terminal_command": "terminal_tool",
          "browser_action": "browser_tool",
          "search_action": "search_tool",
          "complete": "task_complete"
        }
      },
      "file_tool": {
        "@type": "tool/execute",
        "tool_id": "file_editor",
        "next": "result_process"
      },
      "terminal_tool": {
        "@type": "tool/execute",
        "tool_id": "terminal",
        "next": "result_process"
      },
      "browser_tool": {
        "@type": "tool/execute",
        "tool_id": "browser",
        "next": "result_process"
      },
      "search_tool": {
        "@type": "tool/execute",
        "tool_id": "search",
        "next": "result_process"
      },
      "result_process": {
        "@type": "π/transform",
        "operation": "process_result",
        "next": "loop_check"
      },
      "loop_check": {
        "@type": "control/branch",
        "conditions": {
          "continue": "action_plan",
          "max_iterations": "task_complete",
          "error": "error_recovery"
        }
      },
      "error_recovery": {
        "@type": "π/transform",
        "operation": "recover_from_error",
        "next": "action_plan"
      },
      "task_complete": {
        "@type": "data/output",
        "format": "task_result"
      }
    }
  },

  "compression": {
    "@law": "CC-v1",
    "operators": ["⊕", "π̂", "⊗", "≈", "τ"],
    "agent_compression": {
      "action_deduplication": true,
      "context_summarization": true,
      "tool_result_compression": true
    }
  },

  "capabilities": {
    "file_editing": true,
    "terminal_execution": true,
    "browser_automation": true,
    "code_search": true,
    "multi_step_tasks": true,
    "error_recovery": true
  },

  "java_binding": {
    "@doc": "Java runtime integration",
    "package": "com.cline.agent",
    "main_class": "ClineAgent",
    "jvm_options": ["-Xmx4g", "-XX:+UseG1GC"]
  },

  "adapters": {
    "kuhul_pi": {
      "wave_transform": true,
      "golden_compression": true,
      "agent_glyph": true
    }
  }
}
