      "bindings": { "pi_inputs": ["delta"], "cluster_inputs": ["base_hash"], "runtime_outputs": ["seal"] }
    },

    { "id": "truth_merge", "domain": "cluster", "svg_ref": "brains/truth_merge.svg",
      "metrics": [
