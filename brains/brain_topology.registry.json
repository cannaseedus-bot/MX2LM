      ],
      "bindings": { "pi_inputs": ["deltas"], "cluster_inputs": ["epochs"], "runtime_outputs": ["merge_result"] }
    },

    { "id": "meshchain_core", "domain": "runtime", "svg_ref": "brains/meshchain_core.svg",
