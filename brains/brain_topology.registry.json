{
  "@context": "xjson://xcfe/registry/brain_topology/v1",
  "@law": "Ω-BLACK-PANEL",
  "@version": 1,

  "brains": [
    { "id": "identity_root", "domain": "cluster", "svg_ref": "brains/identity_root.svg",
      "metrics": [
        { "key": "stability", "type": "float", "value": 0.99 },
        { "key": "merge_weight", "type": "float", "value": 0.85 }
      ],
      "bindings": { "pi_inputs": ["epoch"], "cluster_inputs": ["truth_hash"], "runtime_outputs": ["identity_seal"] }
    },

    { "id": "invariant_seal", "domain": "verification", "svg_ref": "brains/invariant_seal.svg",
