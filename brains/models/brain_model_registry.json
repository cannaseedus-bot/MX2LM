{
  "@context": "kuhul://brain/models/registry/v1",
  "@law": "OMEGA-BLACK-PANEL",
  "@version": "1.0.0",

  "description": "Registry of pluggable brain models for MX2LM orchestration",

  "model_types": {
    "LOCAL_WEBLLM": {
      "description": "Browser-based LLM via WebLLM/WebGPU",
      "runtime": "client",
      "requires_gpu": true,
      "latency": "low",
      "privacy": "full"
    },
    "API_EXTERNAL": {
      "description": "External API-based models",
      "runtime": "remote",
      "requires_gpu": false,
      "latency": "medium",
      "privacy": "partial"
    },
    "GLYPH_NATIVE": {
      "description": "MX2LM native glyph-based brain",
      "runtime": "client",
      "requires_gpu": false,
      "latency": "very_low",
      "privacy": "full"
    }
  },

  "models": {
    "mistral_glyph": {
      "id": "mistral_glyph",
      "name": "Mistral MX2LM Glyph Brain",
      "type": "GLYPH_NATIVE",
      "spec_file": "mistral_mx2lm_brain.json",
      "capabilities": ["math", "compression", "self_modify", "research"],
      "learning_enabled": true,
      "priority": 1
    },

    "webllm_phi3": {
      "id": "webllm_phi3",
      "name": "Phi-3 Mini (WebLLM)",
      "type": "LOCAL_WEBLLM",
      "model_id": "Phi-3-mini-4k-instruct-q4f16_1-MLC",
      "capabilities": ["chat", "reasoning", "code"],
      "learning_enabled": true,
      "priority": 2,
      "config": {
        "temperature": 0.7,
        "max_tokens": 1024,
        "top_p": 0.95
      }
    },

    "webllm_llama": {
      "id": "webllm_llama",
      "name": "Llama 3.2 1B (WebLLM)",
      "type": "LOCAL_WEBLLM",
      "model_id": "Llama-3.2-1B-Instruct-q4f16_1-MLC",
      "capabilities": ["chat", "reasoning"],
      "learning_enabled": true,
      "priority": 3,
      "config": {
        "temperature": 0.7,
        "max_tokens": 1024
      }
    },

    "webllm_legacy": {
      "id": "webllm_legacy",
      "name": "legacy2.5 1.5B (WebLLM)",
      "type": "LOCAL_WEBLLM",
      "model_id": "legacy2.5-1.5B-Instruct-q4f16_1-MLC",
      "capabilities": ["chat", "reasoning", "math"],
      "learning_enabled": true,
      "priority": 4,
      "config": {
        "temperature": 0.7,
        "max_tokens": 1024
      }
    },

    "openrouter_legacy": {
      "id": "openrouter_legacy",
      "name": "legacy R1 (OpenRouter)",
      "type": "API_EXTERNAL",
      "provider": "openrouter",
      "model_id": "legacy/legacy-r1",
      "capabilities": ["chat", "reasoning", "math", "code"],
      "learning_enabled": true,
      "priority": 5,
      "requires_api_key": true,
      "env_key": "OPENROUTER_API_KEY"
    },

    "openrouter_claude": {
      "id": "openrouter_claude",
      "name": "Claude 3.5 Sonnet (OpenRouter)",
      "type": "API_EXTERNAL",
      "provider": "openrouter",
      "model_id": "anthropic/claude-3.5-sonnet",
      "capabilities": ["chat", "reasoning", "code", "analysis"],
      "learning_enabled": true,
      "priority": 6,
      "requires_api_key": true,
      "env_key": "OPENROUTER_API_KEY"
    },

    "legacy_multimodal": {
      "id": "legacy_multimodal",
      "name": "legacy Pro 7B",
      "type": "API_EXTERNAL",
      "provider": "custom",
      "model_id": "legacy-ai/legacy-Pro-7B",
      "capabilities": ["chat", "vision", "generation"],
      "learning_enabled": true,
      "priority": 7,
      "requires_api_key": true,
      "env_key": "legacy_API_KEY"
    }
  },

  "routing_rules": {
    "math_queries": ["mistral_glyph", "openrouter_legacy", "webllm_legacy"],
    "code_queries": ["openrouter_legacy", "openrouter_claude", "webllm_phi3"],
    "vision_queries": ["legacy_multimodal"],
    "general_chat": ["webllm_phi3", "webllm_llama", "openrouter_claude"],
    "fast_response": ["mistral_glyph", "webllm_phi3"],
    "high_quality": ["openrouter_legacy", "openrouter_claude"]
  },

  "learning_config": {
    "absorb_from_external": true,
    "rlhf_collection": true,
    "weight_update_threshold": 0.1,
    "learning_rate": 0.001,
    "decay_rate": 0.99,
    "batch_size": 32
  }
}
