{
  "$id": "asx://binding/brain_topology/svg.v1",
  "$schema": "xjson://xcfe/schema/v1",

  "@context": "asx://brain/topology/bindings/svg/v1",
  "@version": "1.0.0",

  "@authority": "KUHUL_XCFE_OMEGA",
  "@mutation": "forbidden",
  "@extension": "append_only",
  "@executable": false,

  "@description": "Authoritative binding table mapping brain topology IDs to sanitized, non-executable SVG assets. SVGs are visual-only projections. No runtime logic allowed.",

  "@rules": {
    "@svg_policy": "SANITIZED_NO_SCRIPT_NO_EVENT_NO_ANIMATION",
    "@binding_mode": "id_to_asset_only",
    "@runtime_execution": false,
    "@projection_only": true
  },

  "@bindings": [
    /* =========================
       ATOMIC DOMAIN (8)
       ========================= */

    { "id": "orbital_halo",        "svg": "brains/orbital_halo.svg",        "domain": "atomic" },
    { "id": "stack_grid",          "svg": "brains/stack_grid.svg",          "domain": "atomic" },
    { "id": "fractal_lattice",     "svg": "brains/fractal_lattice.svg",     "domain": "atomic" },
    { "id": "weight_flow_river",   "svg": "brains/weight_flow_river.svg",   "domain": "atomic" },
    { "id": "confidence_rings",    "svg": "brains/confidence_rings.svg",    "domain": "atomic" },
    { "id": "decision_fork",       "svg": "brains/decision_fork.svg",       "domain": "atomic" },
    { "id": "collapse_cone",       "svg": "brains/collapse_cone.svg",       "domain": "atomic" },
    { "id": "entropy_field",       "svg": "brains/entropy_field.svg",       "domain": "atomic" },

    /* =========================
       CLUSTER DOMAIN (6)
       ========================= */

    { "id": "cluster_constellation", "svg": "brains/cluster_constellation.svg", "domain": "cluster" },
    { "id": "delta_stream",          "svg": "brains/delta_stream.svg",          "domain": "cluster" },
    { "id": "merge_weave",           "svg": "brains/merge_weave.svg",           "domain": "cluster" },
    { "id": "conflict_knot",         "svg": "brains/conflict_knot.svg",         "domain": "cluster" },
    { "id": "epoch_ladder",          "svg": "brains/epoch_ladder.svg",          "domain": "cluster" },
    { "id": "hash_anchor",           "svg": "brains/hash_anchor.svg",           "domain": "cluster" },

    /* =========================
       TRAINING DOMAIN (5)
       ========================= */

    { "id": "reward_gradient",    "svg": "brains/reward_gradient.svg",    "domain": "training" },
    { "id": "penalty_sink",       "svg": "brains/penalty_sink.svg",       "domain": "training" },
    { "id": "pattern_miner",      "svg": "brains/pattern_miner.svg",      "domain": "training" },
    { "id": "routine_spiral",     "svg": "brains/routine_spiral.svg",     "domain": "training" },
    { "id": "memory_strata",      "svg": "brains/memory_strata.svg",      "domain": "training" },

    /* =========================
       REPLAY DOMAIN (5)
       ========================= */

    { "id": "trace_timeline",     "svg": "brains/trace_timeline.svg",     "domain": "replay" },
    { "id": "replay_mirror",      "svg": "brains/replay_mirror.svg",      "domain": "replay" },
    { "id": "proof_chain",        "svg": "brains/proof_chain.svg",        "domain": "replay" },
    { "id": "verification_gate",  "svg": "brains/verification_gate.svg",  "domain": "replay" },
    { "id": "causality_graph",    "svg": "brains/causality_graph.svg",    "domain": "replay" },

    /* =========================
       RUNTIME DOMAIN (6)
       ========================= */

    { "id": "hud_ring",           "svg": "brains/hud_ring.svg",           "domain": "runtime" },
    { "id": "tunnel_rail",        "svg": "brains/tunnel_rail.svg",        "domain": "runtime" },
    { "id": "api_mesh",           "svg": "brains/api_mesh.svg",           "domain": "runtime" },
    { "id": "io_portal",          "svg": "brains/io_portal.svg",          "domain": "runtime" },
    { "id": "security_shell",     "svg": "brains/security_shell.svg",     "domain": "runtime" },
    { "id": "system_singularity", "svg": "brains/system_singularity.svg", "domain": "runtime" }
  ]
}
