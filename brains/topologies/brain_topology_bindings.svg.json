{
  "$id": "asx://binding/brain_topology/svg.v1",
  "$schema": "xjson://xcfe/schema/v1",

  "@context": "asx://brain/topology/bindings/svg/v1",
  "@version": "1.0.0",

  "@authority": "KUHUL_XCFE_OMEGA",
  "@mutation": "forbidden",
  "@extension": "append_only",
  "@executable": false,

  "@description": "Authoritative binding table mapping brain topology IDs to sanitized, non-executable SVG assets. SVGs are visual-only projections. No runtime logic allowed.",

  "@rules": {
    "@svg_policy": "SANITIZED_NO_SCRIPT_NO_EVENT_NO_ANIMATION",
    "@binding_mode": "id_to_asset_only",
    "@runtime_execution": false,
    "@projection_only": true
  },

  "@bindings": [
    /* =========================
       ATOMIC DOMAIN (10)
       ========================= */

    { "id": "atomic_core",              "svg": "brains/atomic_core.svg",              "domain": "atomic" },
    { "id": "atomic_ring",              "svg": "brains/atomic_ring.svg",              "domain": "atomic" },
    { "id": "atomic_grid",              "svg": "brains/atomic_grid.svg",              "domain": "atomic" },
    { "id": "atomic_stack",             "svg": "brains/atomic_stack.svg",             "domain": "atomic" },
    { "id": "atomic_flow",              "svg": "brains/atomic_flow.svg",              "domain": "atomic" },
    { "id": "atomic_matrix",            "svg": "brains/atomic_matrix.svg",            "domain": "atomic" },
    { "id": "atomic_spine",             "svg": "brains/atomic_spine.svg",             "domain": "atomic" },
    { "id": "atomic_compass",           "svg": "brains/atomic_compass.svg",           "domain": "atomic" },
    { "id": "atomic_cascade",           "svg": "brains/atomic_cascade.svg",           "domain": "atomic" },
    { "id": "atomic_anchor",            "svg": "brains/atomic_anchor.svg",            "domain": "atomic" },

    /* =========================
       CLUSTER DOMAIN (8)
       ========================= */

    { "id": "cluster_constellation",    "svg": "brains/cluster_constellation.svg",    "domain": "cluster" },
    { "id": "cluster_federation",       "svg": "brains/cluster_federation.svg",       "domain": "cluster" },
    { "id": "cluster_mesh",             "svg": "brains/cluster_mesh.svg",             "domain": "cluster" },
    { "id": "cluster_hub",              "svg": "brains/cluster_hub.svg",              "domain": "cluster" },
    { "id": "cluster_orbit",            "svg": "brains/cluster_orbit.svg",            "domain": "cluster" },
    { "id": "cluster_delta",            "svg": "brains/cluster_delta.svg",            "domain": "cluster" },
    { "id": "cluster_merge",            "svg": "brains/cluster_merge.svg",            "domain": "cluster" },
    { "id": "cluster_barrier",          "svg": "brains/cluster_barrier.svg",          "domain": "cluster" },

    /* =========================
       TRAINING DOMAIN (5)
       ========================= */

    { "id": "training_pipeline",        "svg": "brains/training_pipeline.svg",        "domain": "training" },
    { "id": "training_gradient",        "svg": "brains/training_gradient.svg",        "domain": "training" },
    { "id": "training_loss_field",      "svg": "brains/training_loss_field.svg",      "domain": "training" },
    { "id": "training_memory_lattice",  "svg": "brains/training_memory_lattice.svg",  "domain": "training" },
    { "id": "training_convergence",     "svg": "brains/training_convergence.svg",     "domain": "training" },

    /* =========================
       REPLAY DOMAIN (4)
       ========================= */

    { "id": "replay_trace",             "svg": "brains/replay_trace.svg",             "domain": "replay" },
    { "id": "replay_delta",             "svg": "brains/replay_delta.svg",             "domain": "replay" },
    { "id": "replay_verifier",          "svg": "brains/replay_verifier.svg",          "domain": "replay" },
    { "id": "replay_seal",              "svg": "brains/replay_seal.svg",              "domain": "replay" },

    /* =========================
       RUNTIME DOMAIN (3)
       ========================= */

    { "id": "runtime_shell",            "svg": "brains/runtime_shell.svg",            "domain": "runtime" },
    { "id": "runtime_orbital_halo",     "svg": "brains/runtime_orbital_halo.svg",     "domain": "runtime" },
    { "id": "runtime_black_panel",      "svg": "brains/runtime_black_panel.svg",      "domain": "runtime" }
  ]
}
