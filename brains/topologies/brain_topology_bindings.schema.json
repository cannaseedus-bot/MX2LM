{
  "$id": "asx://schema/brain_topology_bindings.svg.v1",
  "$schema": "xjson://xcfe/schema/v1",

  "title": "Brain Topology SVG Bindings Schema",
  "description": "Schema validating the binding between immutable brain topology IDs and sanitized SVG projection assets. Enumeration-only. Non-executable. Ω-law governed.",

  "type": "object",
  "additionalProperties": false,

  "required": [
    "@context",
    "@version",
    "@authority",
    "@mutation",
    "@extension",
    "@executable",
    "@rules",
    "@bindings"
  ],

  "properties": {
    "@context": {
      "type": "string",
      "const": "asx://brain/topology/bindings/svg/v1"
    },

    "@version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },

    "@authority": {
      "type": "string",
      "const": "KUHUL_XCFE_OMEGA"
    },

    "@mutation": {
      "type": "string",
      "const": "forbidden"
    },

    "@extension": {
      "type": "string",
      "const": "append_only"
    },

    "@executable": {
      "type": "boolean",
      "const": false
    },

    "@rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "@svg_policy",
        "@binding_mode",
        "@runtime_execution",
        "@projection_only"
      ],
      "properties": {
        "@svg_policy": {
          "type": "string",
          "const": "SANITIZED_NO_SCRIPT_NO_EVENT_NO_ANIMATION"
        },
        "@binding_mode": {
          "type": "string",
          "const": "id_to_asset_only"
        },
        "@runtime_execution": {
          "type": "boolean",
          "const": false
        },
        "@projection_only": {
          "type": "boolean",
          "const": true
        }
      }
    },

    "@bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/binding_entry"
      }
    }
  },

  "$defs": {
    "binding_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "svg", "domain"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,48}$",
          "description": "Stable brain topology identifier. Must exist in brain_topology_registry.json."
        },

        "svg": {
          "type": "string",
          "pattern": "^brains\\/[a-z0-9_\\-]+\\.svg$",
          "description": "Relative path to a sanitized SVG asset. No inline data URIs allowed."
        },

        "domain": {
          "type": "string",
          "enum": [
            "atomic",
            "cluster",
            "training",
            "replay",
            "runtime"
          ],
          "description": "Functional domain this topology belongs to."
        }
      }
    }
  }
}
