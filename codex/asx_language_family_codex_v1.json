      "@status": "frozen",
      "@role": "geometry_to_lanes_mapping",
      "@statement": "Geometry/types MUST map canonically to SCXQ2 lanes with hash-derived dict_id/field_id/batch_id and canonical ordering for proof stability.",
      "@ids": {
        "@dict_id": "H32(\"DICT|\" + category + \"|\" + name)",
        "@field_id": "H32(\"FIELD|\" + dict_name + \"|\" + field_name)",
        "@batch_id": "H32(\"BATCH|\" + type_name + \"|\" + stream_name)"
