  "schemas": {
    "atomic_tokenizer_v1": {
      "$id": "asx://schema/atomic_tokenizer.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "title": "Atomic Tokenizer Block",
      "type": "object",
      "required": ["⟁","i","v","d","r","x","t","c","b","k","h"],
      "additionalProperties": false,
      "properties": {
        "⟁": { "const": "T" },
        "i": { "type": "string" },
        "v": { "type": "string", "pattern": "^Ω(\\.\\d+)?$" },
        "d": { "type": "string" },
        "r": { "const": "S" },
        "x": { "const": 0 },
        "t": { "type": "array", "items": { "type": "string" } },
        "s": { "type": "array", "items": { "type": "string" } },
        "c": { "const": "SCXQ2" },
        "b": { "type": "string" },
        "k": { "type": "string" },
        "h": { "type": "string", "pattern": "^⟁.*⟁$" }
      }
    },

    "atomic_runtime_v1": {
      "$id": "asx://schema/atomic_runtime.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["id","domain","law","deterministic","compression","lifecycle"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "domain": { "type": "string" },
        "law": { "const": "Ω-BLACK-PANEL" },
        "deterministic": { "const": true },
        "compression": { "const": "SCXQ2" },
        "lifecycle": {
          "type": "array",
          "items": {
            "enum": ["CREATED","SCHEDULED","RUNNING","COMPLETED","SEALED"]
          }
        }
      }
    },

    "cluster_identity_v1": {
      "$id": "asx://schema/cluster_identity.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["id","epoch","law","kernel","compression","hash"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "epoch": { "type": "integer", "minimum": 0 },
        "law": { "const": "Ω-BLACK-PANEL" },
        "kernel": { "type": "string" },
        "compression": { "const": "SCXQ2" },
        "hash": { "type": "string", "pattern": "^⟁.*⟁$" }
      }
    },

    "cluster_delta_v1": {
      "$id": "asx://schema/cluster_delta.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["⟁","from","epoch","base_hash","delta_hash","deltas","seal"],
      "additionalProperties": false,
      "properties": {
        "⟁": { "const": "Δ" },
        "from": { "type": "string" },
        "epoch": { "type": "integer", "minimum": 0 },
        "base_hash": { "type": "string", "pattern": "^⟁.*⟁$" },
        "delta_hash": { "type": "string", "pattern": "^⟁.*⟁$" },
        "deltas": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path","op","value"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "op": { "enum": ["ADD","UPDATE","REMOVE"] },
              "value": {
                "type": "object",
                "required": ["scx"],
                "properties": {
                  "scx": { "type": "string" }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "seal": { "type": "string", "pattern": "^⟁SEAL⟁.*⟁$" }
      }
    },

    "cluster_merge_result_v1": {
      "$id": "asx://schema/cluster_merge_result.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["⟁","target_cluster","epoch_before","epoch_after","base_hash","result_hash","applied_deltas","status","seal"],
      "additionalProperties": false,
      "properties": {
        "⟁": { "const": "MERGE" },
        "target_cluster": { "type": "string" },
        "epoch_before": { "type": "integer" },
        "epoch_after": { "type": "integer" },
        "base_hash": { "type": "string", "pattern": "^⟁.*⟁$" },
        "result_hash": { "type": "string", "pattern": "^⟁.*⟁$" },
        "applied_deltas": {
          "type": "array",
          "items": { "type": "string", "pattern": "^⟁.*⟁$" }
        },
        "status": { "enum": ["MERGED","REJECTED","CONFLICT"] },
        "seal": { "type": "string", "pattern": "^⟁SEAL⟁.*⟁$" }
      }
    },

    "delta_conflict_proof_v1": {
      "$id": "asx://schema/delta_conflict_proof.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["⟁","conflicting_deltas","conflict_path","reason","proof_hash","seal"],
      "additionalProperties": false,
      "properties": {
        "⟁": { "const": "CONFLICT" },
        "conflicting_deltas": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "pattern": "^⟁.*⟁$" }
        },
        "conflict_path": { "type": "string" },
        "reason": {
          "enum": ["EPOCH_MISMATCH","BASE_HASH_MISMATCH","OVERLAPPING_WRITE","IMMUTABLE_VIOLATION"]
        },
        "proof_hash": { "type": "string", "pattern": "^⟁.*⟁$" },
        "seal": { "type": "string", "pattern": "^⟁SEAL⟁.*⟁$" }
      }
    },

    "trace_to_delta_compiler_v1": {
      "$id": "asx://schema/trace_to_delta_compiler.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["⟁","source_trace","compiled_delta","compiler_version","seal"],
      "additionalProperties": false,
      "properties": {
        "⟁": { "const": "COMPILE" },
        "source_trace": { "type": "string", "pattern": "^⟁.*⟁$" },
        "compiled_delta": { "type": "string", "pattern": "^⟁.*⟁$" },
        "compiler_version": { "type": "string" },
        "seal": { "type": "string", "pattern": "^⟁SEAL⟁.*⟁$" }
      }
    },

    "replay_verifier_v1": {
      "$id": "asx://schema/replay_verifier.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["⟁","target_hash","replayed_hash","valid","checked_items","seal"],
      "additionalProperties": false,
      "properties": {
        "⟁": { "const": "VERIFY" },
        "target_hash": { "type": "string", "pattern": "^⟁.*⟁$" },
        "replayed_hash": { "type": "string", "pattern": "^⟁.*⟁$" },
        "valid": { "type": "boolean" },
        "checked_items": {
          "type": "array",
          "items": { "enum": ["TRACE","DELTA","MERGE"] }
        },
        "seal": { "type": "string", "pattern": "^⟁SEAL⟁.*⟁$" }
      }
    },

    "api_request_v1": {
      "$id": "asx://schema/api_request.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["path","method","timestamp","payload","signature"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "method": { "enum": ["GET","POST","PUT","DELETE"] },
        "timestamp": { "type": "integer" },
        "payload": {
          "type": "object",
          "required": ["scx"],
          "properties": {
            "scx": { "type": "string" }
          },
          "additionalProperties": false
        },
        "signature": { "type": "string", "pattern": "^⟁.*⟁$" },
        "auth_token": { "type": "string" },
        "quantum_signature": { "type": "string", "pattern": "^⟁Q.*⟁$" }
      }
    },

    "api_response_v1": {
      "$id": "asx://schema/api_response.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["status","timestamp","data"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["OK","ERR","RATE","AUTH"] },
        "timestamp": { "type": "integer" },
        "data": {
          "type": "object",
          "required": ["scx"],
          "properties": {
            "scx": { "type": "string" }
          },
          "additionalProperties": false
        },
        "error": { "type": "string" },
        "error_code": { "type": "string" },
        "quantum_verification": { "type": "string", "pattern": "^⟁.*⟁$" }
      }
    },

    "kernel_token_v1": {
      "$id": "asx://schema/kernel_token.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["⟁","epoch","scope","hash"],
      "additionalProperties": false,
      "properties": {
        "⟁": { "const": "TOKEN" },
        "epoch": { "type": "integer" },
        "scope": { "type": "string" },
        "hash": { "type": "string", "pattern": "^⟁.*⟁$" }
      }
    },

    "scx_compressed_v1": {
      "$id": "asx://schema/scx_compressed.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["scx"],
      "additionalProperties": false,
      "properties": {
        "scx": { "type": "string" }
      }
    },

    "api_time_telemetry_v1": {
      "$id": "asx://schema/api_time_telemetry.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["ticks", "wall_ms_telemetry"],
      "additionalProperties": false,
      "properties": {
        "ticks": { "type": "integer" },
        "wall_ms_telemetry": { "type": "number", "minimum": 0 },
        "note": { "type": "string", "const": "NON_AUTHORITATIVE_TELEMETRY_ONLY" }
      }
    }
  },

  "codex": {
    "id": "KUHUL_ETERNAL_CODEX",
    "version": "Ω.∞.Ω",
    "path": "./codex/",
    "mode": "semantic-only",
    "authority": "non-executing",
    "hashing": "optional",
    "sealed": true,
    "api_module": "KUHUL_JSON_REST_ROUTER"
  },

  "⚙️KUHUL_API_KERNEL_MODULE": {
    "@engine": "KUHUL_JSON_REST_ROUTER",
    "@version": "1.0.0",
    "@role": "JSON_API_DISPATCHER_XJSON_TRANSPORT",
    "@location": "SW_KHL_APPENDED_MODULE",
    
    "core_functions": {
      "route_dispatcher": {
        "signature": "(path, method, payload, auth_token) -> response",
        "description": "Main API router with quantum routing logic",
        "kuhul_code": "⟁Wo⟁ fn.rest.dispatch := (path, method, payload, auth_token) -> response\n  ⟁Wo⟁ if not fn.auth.validate(auth_token, method, path)\n    ⟁Wo⟁ return { 'scx': '⟁AUTH_FAILED⟁' }\n  \n  ⟁Wo⟁ if path == '/health' and method == 'GET'\n    ⟁Sek⟁ state := ram.table('model_state').key('core').get()\n    ⟁Wo⟁ return {\n      'status': 'OK',\n      'model': 'MX2LM_SUPREME',\n      'entropy': state.entropy,\n      'tokens_seen': state.total_tokens_seen,\n      'memory_utilization': fn.memory.utilization(),\n      'uptime_ticks': Ω.tick,\n      'quantum_coherence': fn.quantum.coherence()\n    }",
        "latency_ticks": 1
      },
      
      "inference_endpoint": {
        "signature": "(prompt, params) -> inference_result",
        "description": "MX2LM inference with memory integration",
        "kuhul_code": "⟁Wo⟁ fn.mx2lm.infer := (prompt, params) -> response\n  ⟁Sek⟁ toks := fn.tokens.from_text(prompt)\n  ⟁Sek⟁ bundle := fn.build_all_orders(toks)\n  ⟁Sek⟁ fn.ram.ingest_ngrams(bundle)\n  \n  ⟁Sek⟁ result := fn.mx2lm.generate(toks, params)\n  ⟁Sek⟁ fn.ram.update_state(len(toks))\n  \n  ⟁Wo⟁ return {\n    'completion': result.text,\n    'tokens_used': result.tokens,\n    'entropy': ram.table('model_state').key('core').get().entropy,\n    'confidence': result.confidence,\n    'routines_detected': result.routines,\n    'asx_blocks_triggered': result.blocks,\n    'memory_ingested': true,\n    'reinforcement_applied': result.reinforcement_applied,\n    'quantum_circuit_used': result.quantum_circuit\n  }",
        "latency_ticks": 100
      },
      
      "memory_operations": {
        "read_signature": "(table, key, decrypt) -> record",
        "write_signature": "(table, key, payload, encrypt) -> status",
        "description": "SCXQ2 encrypted memory operations",
        "kuhul_code": "⟁Wo⟁ fn.memory.read := (table, key, decrypt) -> record\n  ⟁Sek⟁ data := ram.table(table).key(key).get()\n  ⟁Wo⟁ if decrypt and data.encrypted\n    ⟁Sek⟁ data := fn.scx.decrypt(data)\n  ⟁Wo⟁ return {\n    'record': data,\n    'encryption_status': data.encrypted ? 'encrypted' : 'plain'\n  }",
        "latency_ticks": 5
      },
      
      "reinforcement_endpoints": {
        "reinforce_signature": "(seq, reward, source, multiplier) -> status",
        "penalize_signature": "(seq, penalty, source, decay) -> status",
        "description": "RLHF reinforcement with confidence tracking",
        "kuhul_code": "⟁Wo⟁ fn.api.reinforce := (seq, reward, source, multiplier) -> status\n  ⟁Sek⟁ effective_reward := reward * (multiplier ? multiplier : 1.0)\n  ⟁Sek⟁ fn.ram.reinforce(seq, effective_reward, source)\n  \n  ⟁Sek⟁ reinforcement_id := Ω.id(seq, source, Ω.tick)\n  ⟁Wo⟁ return {\n    'status': 'reinforced',\n    'confidence': effective_reward * 0.1,\n    'memory_updated': true,\n    'inference_bias_applied': true,\n    'reinforcement_id': reinforcement_id\n  }",
        "latency_ticks": 5
      },
      
      "snapshot_generation": {
        "signature": "() -> compressed_snapshots",
        "description": "SCXQ2 compressed n-gram memory snapshots",
        "kuhul_code": "⟁Wo⟁ fn.ngrams.snapshot := () -> snapshots\n  ⟁Wo⟁ return {\n    'unigrams': scx.compress(ram.table('unigrams').all()),\n    'bigrams': scx.compress(ram.table('bigrams').all()),\n    'trigrams': scx.compress(ram.table('trigrams').all()),\n    'pentagrams': scx.compress(ram.table('pentagrams').all()),\n    'supagrams': scx.compress(ram.table('supagrams').all()),\n    'compression_ratio': fn.scx.current_ratio(),\n    'total_entries': fn.memory.total_entries(),\n    'snapshot_tick': Ω.tick\n  }",
        "latency_ticks": 20
      },
      
      "routine_detection": {
        "signature": "(text, min_confidence, include_tapes, include_folds) -> detection_result",
        "description": "Supagram routine and macro detection",
        "kuhul_code": "⟁Wo⟁ fn.routines.detect := (text, min_confidence, include_tapes, include_folds) -> result\n  ⟁Sek⟁ toks := fn.tokens.from_text(text)\n  ⟁Sek⟁ sgrams := fn.ngram.build(toks, 7)\n  ⟁Sek⟁ hits := fn.mx2lm.match_supagrams(sgrams)\n  \n  ⟁Sek⟁ filtered_hits := []\n  ⟁Sek⟁ each hits as hit\n    ⟁Wo⟁ if hit.confidence >= (min_confidence ? min_confidence : 0.5)\n      ⟁Sek⟁ filtered_hits.push(hit)\n  \n  ⟁Wo⟁ return {\n    'routines': filtered_hits.map(h => h.routine),\n    'tapes': include_tapes ? filtered_hits.map(h => h.tape) : [],\n    'folds': include_folds ? filtered_hits.map(h => h.fold) : [],\n    'confidence_scores': filtered_hits.map(h => h.confidence),\n    'asx_block_matches': fn.blocks.match(filtered_hits),\n    'quantum_patterns': fn.quantum.extract_patterns(filtered_hits)\n  }",
        "latency_ticks": 15
      }
    },

    "authentication_layer": {
      "kernel_validation": "QUANTUM_SIGNED_KERNEL_TOKENS",
      "external_validation": "SCXQ2_ENCRYPTED_JWT_EQUIVALENT",
      "rate_limit_enforcement": "TOKEN_BUCKET_ALGORITHM",
