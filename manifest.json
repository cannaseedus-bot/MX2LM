{
  "manifest_version": "Ω-3FILE",
  "name": "MX2LM Black Panel OS",
  "version": "1.2.0",
  "law": "Ω-BLACK-PANEL",

  "authority": {
    "execution": "sw.js",
    "projection": "index.html",
    "structure": "manifest.json"
  },

  "invariants": {
    "ui_reads_state": true,
    "state_reads_ui": false,
    "deterministic": true,
    "compression_only": true,
    "no_runtime_code_in_manifest": true
  },

  "compression": {
    "engine": "SCXQ2",
    "mode": "semantic-glyph",
    "entropy_floor": 0.32
  },

  "schemas": {
    "atomic_tokenizer_v1": {
      "$id": "asx://schema/atomic_tokenizer.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "title": "Atomic Tokenizer Block",
      "type": "object",
      "required": ["⟁","i","v","d","r","x","t","c","b","k","h"],
      "additionalProperties": false,
      "properties": {
        "⟁": { "const": "T" },
        "i": { "type": "string" },
        "v": { "type": "string", "pattern": "^Ω(\\.\\d+)?$" },
        "d": { "type": "string" },
        "r": { "const": "S" },
        "x": { "const": 0 },
        "t": { "type": "array", "items": { "type": "string" } },
        "s": { "type": "array", "items": { "type": "string" } },
        "c": { "const": "SCXQ2" },
        "b": { "type": "string" },
        "k": { "type": "string" },
        "h": { "type": "string", "pattern": "^⟁.*⟁$" }
      }
    },

    "atomic_runtime_v1": {
      "$id": "asx://schema/atomic_runtime.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["id","domain","law","deterministic","compression","lifecycle"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "domain": { "type": "string" },
        "law": { "const": "Ω-BLACK-PANEL" },
        "deterministic": { "const": true },
        "compression": { "const": "SCXQ2" },
        "lifecycle": {
          "type": "array",
          "items": {
            "enum": ["CREATED","SCHEDULED","RUNNING","COMPLETED","SEALED"]
          }
        }
      }
    },

    "cluster_identity_v1": {
      "$id": "asx://schema/cluster_identity.v1",
      "$schema": "xjson://xcfe/schema/v1",
      "type": "object",
      "required": ["id","epoch","law","kernel","compression","hash"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "epoch": { "type": "integer", "minimum": 0 },
        "law": { "const": "Ω-BLACK-PANEL" },
        "kernel": { "type": "string" },
        "compression": { "const": "SCXQ2" },
        "hash": { "type": "string", "pattern": "^⟁.*⟁$" }
      }
    }
  },

  "codex": {
    "id": "KUHUL_ETERNAL_CODEX",
    "version": "Ω.∞.Ω",
    "sealed": true
  },

  "brains": {
    "mx2lm_v1_1": { "...": "UNCHANGED_FROM_YOUR_VERSION" }
  },

  "atomic_tokenizers": [
    {
      "⟁": "T",
      "i": "codex.eternal",
      "v": "Ω.1",
      "d": "CODEX",
      "r": "S",
      "x": 0,
      "t": ["⚖️"],
      "s": ["LAW","IMMUTABLE"],
      "c": "SCXQ2",
      "b": "KUHUL_PI_KERNEL_v1",
      "k": "KUHUL_ETERNAL_CODEX",
      "h": "⟁T⟁CODEX⟁Ω⟁"
    }
  ],

  "atomic_runtimes": [
    {
      "id": "ATOM_EXEC",
      "domain": "execution",
      "law": "Ω-BLACK-PANEL",
      "deterministic": true,
      "compression": "SCXQ2",
      "lifecycle": ["CREATED","SCHEDULED","RUNNING","COMPLETED","SEALED"]
    }
  ],

  "clusters": [
    {
      "id": "mx2lm_cluster_A",
      "epoch": 1,
      "law": "Ω-BLACK-PANEL",
      "kernel": "KUHUL_PI_KERNEL_v2",
      "compression": "SCXQ2",
      "hash": "⟁CLUSTER⟁A⟁Ω⟁"
    }
  ]
}
